<group name="windows, sysmon, credential_access,">
  <rule id="100002" level="12">
    <if_sid>61610</if_sid>
    <field name="win.system.eventID">^10$</field>
    <field name="win.eventdata.targetImage">lsass.exe</field>
    <field name="win.eventdata.grantedAccess">0x1010|0x1410|0x143a</field>
    <description>Potential LSASS memory dump detected.</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
  </rule>
</group>
